---
// src/components/SemuaProyek.astro
import { Building2, Calendar, CheckCircle2, ImageOff } from 'lucide-astro';
import '../styles/global.css';

const allProjects = [
  { title: "Instalasi Gedung Perkantoran Sudirman", category: "Gedung", year: "2026", img: "/img/proyek-1.jpg" },
  { title: "Sistem Panel PDB Pabrik Tekstil", category: "Industri", year: "2026", img: "/img/proyek-2.jpg" },
  { title: "Maintenance Gardu Listrik Mall Tegal", category: "Maintenance", year: "2025", img: "/img/proyek-3.jpg" },
  { title: "Instalasi Ruko 3 Lantai Brebes", category: "Komersial", year: "2025", img: "/img/proyek-4.jpg" },
  { title: "Smart Home Luxury Residence", category: "Residensial", year: "2025", img: "/img/proyek-5.jpg" },
  { title: "Upgrade Daya Pabrik Konveksi", category: "Industri", year: "2024", img: "/img/proyek-6.jpg" },
  { title: "Penerangan Gudang Logistik Utama", category: "Logistik", year: "2024", img: "/img/proyek-7.jpg" },
  { title: "Perbaikan Jaringan Listrik RSUD", category: "Fasilitas Publik", year: "2024", img: "/img/proyek-8.jpg" },
  { title: "Instalasi Listrik Komplek Perumahan", category: "Residensial", year: "2023", img: "/img/proyek-9.jpg" },
  { title: "Panel Distribusi Workshop SMK", category: "Edukasi", year: "2023", img: "/img/proyek-10.jpg" },
];
---

<section id="semua-proyek" class="py-24 bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="mb-16 text-center">
      <h2 class="text-xs font-bold tracking-wider uppercase text-accent mb-2">Portfolio Lengkap</h2>
      <p class="text-3xl md:text-4xl font-extrabold text-primary">Daftar Proyek Kami</p>
      <div class="w-16 h-1 bg-accent mx-auto mt-5"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {allProjects.map((project) => (
        <div class="bg-surface border border-border-custom rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-all group">
          
          <!-- Area Gambar dengan Pratinjau -->
          <div class="h-40 bg-slate-100 relative overflow-hidden flex flex-col items-center justify-center">
            <!-- Ikon Pratinjau -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 group-hover:text-accent transition-colors">
              <ImageOff class="w-8 h-8 stroke-[1.5]" />
              <span class="text-[10px] uppercase tracking-widest font-semibold mt-1 opacity-60">Pratinjau</span>
            </div>

            <!-- Gambar Asli -->
            <img 
              src={project.img} 
              alt={project.title}
              class="w-full h-full object-cover relative z-10 opacity-100 transition-opacity duration-300"
              onerror="this.style.opacity='0'"
            />
          </div>

          <div class="p-5">
            <div class="flex justify-between items-start mb-3">
              <span class="text-[10px] font-bold uppercase tracking-wider text-accent bg-accent/10 px-2 py-0.5 rounded">
                {project.category}
              </span>
              <span class="flex items-center gap-1 text-[10px] text-text-light font-medium">
                <Calendar class="w-3 h-3" /> {project.year}
              </span>
            </div>
            
            <h3 class="font-bold text-primary text-sm leading-snug group-hover:text-accent transition-colors">
              {project.title}
            </h3>
            
            <div class="mt-4 pt-4 border-t border-border-custom">
              <span class="flex items-center gap-1.5 text-[11px] font-bold text-emerald-600">
                <CheckCircle2 class="w-3 h-3" /> Selesai
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>