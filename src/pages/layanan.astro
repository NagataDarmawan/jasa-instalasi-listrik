---
// src/components/Services.astro
import { ArrowUpRight, ImageOff } from 'lucide-astro';
import '../styles/global.css';

const services = [
  { id: "serv-1", title: "Instalasi Listrik Rumah", description: "Perencanaan dan pemasangan jalur kabel baru, titik saklar, lampu, dan stop kontak dengan teknik perutean rapi tersembunyi di dalam dinding.", image: "/img/instalasi-rumah.jpg" },
  { id: "serv-2", title: "Instalasi Listrik Ruko", description: "Integrasi sistem kelistrikan komersial untuk kebutuhan display toko, pencahayaan etalase, serta pembagian sirkuit elektronik yang aman.", image: "/img/instalasi-ruko.jpg" },
  { id: "serv-3", title: "Instalasi Kantor", description: "Pemasangan jaringan listrik terstruktur untuk area kubikal kerja, server, ruang rapat, serta optimasi penempatan kabel lantai (underfloor casing).", image: "/img/instalasi-kantor.jpg" },
  { id: "serv-4", title: "Instalasi Gudang", description: "Sistem pencahayaan high-bay berdaya tinggi dan pengaturan jalur suplai daya yang efisien untuk mendukung operasional logistik nonstop.", image: "/img/instalasi-gudang.jpg" },
  { id: "serv-5", title: "Instalasi Pabrik Ringan", description: "Penyusunan transmisi daya yang stabil untuk mesin produksi skala kecil-menengah dengan perhitungan beban puncak guna mencegah trip.", image: "/img/instalasi-pabrik.jpg" },
  { id: "serv-6", title: "Penambahan Daya & Migrasi", description: "Pengurusan administrasi dan pengerjaan teknis peningkatan kapasitas daya PLN, penggantian kabel utama (kesiapan beban baru), hingga migrasi prabayar.", image: "/img/tambah-daya.jpg" },
  { id: "serv-7", title: "Pemasangan & Upgrade MCB", description: "Penggantian komponen MCB usang, pembagian group sirkuit baru, dan kalibrasi pengaman guna meminimalkan risiko korsleting fatal.", image: "/img/pasang-mcb.jpg" },
  { id: "serv-8", title: "Instalasi Panel Listrik (PDB)", description: "Perakitan, penataan, dan pemasangan panel distribusi utama beserta sistem grounding protektif untuk pembagian beban yang seimbang.", image: "/img/panel-listrik.jpg" },
  { id: "serv-9", title: "Perbaikan Instalasi & Troubleshooting", description: "Deteksi titik kebocoran arus korsleting kronis, perbaikan kabel digigit hama, penyambungan ulang isolasi, dan penanganan darurat listrik mati sebagian.", image: "/img/perbaikan-listrik.jpg" },
  { id: "serv-10", title: "Maintenance Berkala (K3)", description: "Inspeksi termografi berkala pada sambungan kabel utama, pembersihan panel, pengujian grounding, dan sertifikasi kelayakan berkala.", image: "/img/maintenance-listrik.jpg" }
];
---

<section id="layanan" class="py-24 bg-white border-b border-border-custom/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="mb-12">
      <h2 class="text-xs font-bold tracking-wider uppercase text-accent mb-2">Layanan Profesional</h2>
      <p class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-tight text-primary">
        Solusi Kelistrikan Terintegrasi Berstandar PUIL
      </p>
      <div class="w-16 h-1 bg-accent mt-4"></div>
    </div>

    <div class="bg-slate-50 border border-border-custom/50 rounded-2xl overflow-hidden grid grid-cols-1 lg:grid-cols-12 gap-0 shadow-sm">
      
      <div class="lg:col-span-4 bg-slate-100 relative min-h-[280px] lg:min-h-[480px] overflow-hidden flex items-center justify-center pointer-events-none">
        <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400">
          <ImageOff class="w-10 h-10 stroke-[1.5]" />
          <span class="text-[10px] uppercase tracking-widest font-bold mt-2 opacity-60">Pratinjau Gambar</span>
        </div>

        {services.map((item, index) => (
          <img 
            id={`img-${item.id}`}
            src={item.image} 
            alt={item.title}
            loading="lazy"
           
            class={`w-full h-full object-cover absolute inset-0 z-10 pointer-events-none transition-none transform-none ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
            onerror="this.style.opacity='0';" 
          />
        ))}
      </div>

      <div class="lg:col-span-8 p-6 sm:p-8 flex flex-col justify-between bg-white border-l border-border-custom/30">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-1">
          {services.map((item, index) => {
            const isFirst = index === 0;
            return (
              <div class="border-b border-slate-100 py-1">
                <button
                  data-target={item.id}
                  
                  class="service-trigger w-full text-left py-2 flex items-start gap-3 transition-all"
                >
                  {/* Indikator Baris Sisi Kiri */}
                  <div class={`w-1 h-5 shrink-0 transition-colors duration-300 rounded-full mt-1 ${isFirst ? 'bg-accent' : 'bg-slate-200'}`}></div>
                  
                  <div class="w-full">
                    {/* PERBAIKAN: Menghapus group-hover:text-primary */}
                    <h3 class={`font-bold text-sm md:text-base tracking-tight transition-colors duration-300 ${isFirst ? 'text-primary' : 'text-slate-400'}`}>
                      {item.title}
                    </h3>
                    
                    {/* Deskripsi Box */}
                    <div 
                      id={`desc-${item.id}`}
                      class={`service-desc overflow-hidden transition-all duration-300 ease-in-out ${isFirst ? 'max-h-40 opacity-100 mt-1.5' : 'max-h-0 opacity-0'}`}
                    >
                      <p class="text-xs text-text-light leading-relaxed pr-2">
                        {item.description}
                      </p>
                    </div>
                  </div>
                </button>
              </div>
            )
          })}
        </div>

        <div class="mt-8 pt-4 border-t border-slate-100 flex justify-end">
          <a 
            href="/catalogLayanan"
            class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-accent bg-primary hover:bg-primary/90 py-3.5 px-6 rounded-md transition-all duration-200 shadow-md group"
          >
            <span>Pesan Jasa Sekarang</span>
            <ArrowUpRight class="w-4 h-4 text-accent transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
          </a>
        </div>

      </div>

    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.service-trigger');
    
    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const targetId = trigger.getAttribute('data-target');
        if (!targetId) return;

        // Reset semua menu ke kondisi mati (Muted)
        triggers.forEach(t => {
          const tId = t.getAttribute('data-target');
          const indicator = t.querySelector('.w-1');
          const title = t.querySelector('h3');
          const desc = document.getElementById(`desc-${tId}`);
          const img = document.getElementById(`img-${tId}`);

          indicator?.classList.remove('bg-accent');
          indicator?.classList.add('bg-slate-200');
          title?.classList.remove('text-primary');
          title?.classList.add('text-slate-400');
          
          if (desc) {
            desc.classList.remove('max-h-40', 'opacity-100', 'mt-1.5');
            desc.classList.add('max-h-0', 'opacity-0');
          }
          if (img) {
            img.classList.remove('opacity-100');
            img.classList.add('opacity-0');
          }
        });

        // Aktifkan murni hanya yang di-KLIK oleh user
        const currentIndicator = trigger.querySelector('.w-1');
        const currentTitle = trigger.querySelector('h3');
        const currentDesc = document.getElementById(`desc-${targetId}`);
        const currentImg = document.getElementById(`img-${targetId}`);

        currentIndicator?.classList.remove('bg-slate-200');
        currentIndicator?.classList.add('bg-accent');
        currentTitle?.classList.remove('text-slate-400');
        currentTitle?.classList.add('text-primary');

        if (currentDesc) {
          currentDesc.classList.remove('max-h-0', 'opacity-0');
          currentDesc.classList.add('max-h-40', 'opacity-100', 'mt-1.5');
        }
        if (currentImg) {
          currentImg.classList.remove('opacity-0');
          currentImg.classList.add('opacity-100');
        }
      });
    });
  });
</script>