---
// src/components/formPemesanan.astro
import { User, Phone, MapPin, Wrench, Calendar, FileText, Send } from 'lucide-astro';
import '../styles/global.css';

const serviceOptions = [
  { slug: "instalasi-listrik-rumah", name: "Instalasi Listrik Rumah" },
  { slug: "instalasi-listrik-ruko", name: "Instalasi Listrik Ruko & Toko" },
  { slug: "penambahan-daya", name: "Penambahan Daya Listrik" },
  { slug: "pemasangan-mcb", name: "Pemasangan & Penggantian MCB" },
  { slug: "perbaikan-instalasi", name: "Perbaikan Instalasi Listrik" },
  { slug: "pemasangan-lampu-stop-kontak", name: "Pemasangan Lampu & Stop Kontak" },
  { slug: "pengecekan-perawatan-instalasi", name: "Pengecekan & Perawatan Instalasi" }
];
---

<div class="w-full bg-surface p-6 sm:p-8 rounded-2xl">
  <div class="mb-6 space-y-2">
    <h3 class="text-xl font-black text-primary tracking-tight">Formulir Pemesanan Jasa</h3>
    <p class="text-xs text-text-light leading-relaxed">
      Lengkapi data di bawah ini. Tim teknis BREGAS ELEKTRIK akan segera menghubungi Anda untuk konfirmasi jadwal survei lapangan.
    </p>
  </div>

  <form id="order-form" class="space-y-4">
    
    <div class="space-y-1.5">
      <label for="client-name" class="text-xs font-bold text-primary uppercase tracking-wider block">Nama Lengkap</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-text-light">
          <User class="w-4 h-4 stroke-[2]" />
        </div>
        <input 
          type="text" 
          id="client-name" 
          name="name" 
          required 
          placeholder="Masukkan nama Anda"
          class="w-full pl-10 pr-4 py-3 bg-background border border-border-custom/80 rounded-xl text-sm focus:outline-hidden focus:border-accent focus:ring-1 focus:ring-accent transition-all placeholder:text-text-light/50 font-medium"
        />
      </div>
    </div>

    <div class="space-y-1.5">
      <label for="client-phone" class="text-xs font-bold text-primary uppercase tracking-wider block">Nomor WhatsApp Aktif (Wajib)</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-text-light">
          <Phone class="w-4 h-4 stroke-[2]" />
        </div>
        <input 
          type="tel" 
          id="client-phone" 
          name="phone" 
          required 
          placeholder="Contoh: 08123456789"
          class="w-full pl-10 pr-4 py-3 bg-background border border-border-custom/80 rounded-xl text-sm focus:outline-hidden focus:border-accent focus:ring-1 focus:ring-accent transition-all placeholder:text-text-light/50 font-medium"
        />
      </div>
    </div>

    <div class="space-y-1.5">
      <label for="client-address" class="text-xs font-bold text-primary uppercase tracking-wider block">Alamat Lokasi Proyek</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-text-light">
          <MapPin class="w-4 h-4 stroke-[2]" />
        </div>
        <input 
          type="text" 
          id="client-address" 
          name="address" 
          required 
          placeholder="Nama jalan, nomor rumah, kota/kecamatan"
          class="w-full pl-10 pr-4 py-3 bg-background border border-border-custom/80 rounded-xl text-sm focus:outline-hidden focus:border-accent focus:ring-1 focus:ring-accent transition-all placeholder:text-text-light/50 font-medium"
        />
      </div>
    </div>

    <div class="space-y-1.5">
      <label for="client-service" class="text-xs font-bold text-primary uppercase tracking-wider block">Jenis Layanan</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-text-light">
          <Wrench class="w-4 h-4 stroke-[2]" />
        </div>
        
        {/* PERBAIKAN: Menambahkan atribut 'disabled' dan mengubah style visual agar terkunci */}
        <select 
          id="client-service" 
          name="service" 
          required 
          disabled
          class="w-full pl-10 pr-10 py-3 bg-slate-50 border border-border-custom/80 rounded-xl text-sm text-slate-500 cursor-not-allowed font-medium appearance-none"
        >
          <option value="" disabled selected>Pilih jenis layanan teknis</option>
          {serviceOptions.map((option) => (
            <option value={option.slug}>{option.name}</option>
          ))}
        </select>
        <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none text-text-light">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
        </div>
      </div>
    </div>

    <div class="space-y-1.5">
      <label for="client-schedule" class="text-xs font-bold text-primary uppercase tracking-wider block">Jadwal yang Diinginkan</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-text-light">
          <Calendar class="w-4 h-4 stroke-[2]" />
        </div>
        <input 
          type="date" 
          id="client-schedule" 
          name="schedule" 
          required 
          class="w-full pl-10 pr-4 py-3 bg-background border border-border-custom/80 rounded-xl text-sm focus:outline-hidden focus:border-accent focus:ring-1 focus:ring-accent transition-all font-medium text-primary"
        />
      </div>
    </div>

    <div class="space-y-1.5">
      <label for="client-notes" class="text-xs font-bold text-primary uppercase tracking-wider block">Catatan Tambahan (Opsional)</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3.5 pt-3.5 flex items-start pointer-events-none text-text-light">
          <FileText class="w-4 h-4 stroke-[2]" />
        </div>
        <textarea 
          id="client-notes" 
          name="notes" 
          rows="3" 
          placeholder="Jelaskan detail kendala atau spesifikasi khusus jika ada..."
          class="w-full pl-10 pr-4 py-3 bg-background border border-border-custom/80 rounded-xl text-sm focus:outline-hidden focus:border-accent focus:ring-1 focus:ring-accent transition-all placeholder:text-text-light/50 font-medium resize-none"
        ></textarea>
      </div>
    </div>

    <div class="pt-2">
      <button 
        type="submit" 
        class="inline-flex items-center justify-center gap-2 w-full bg-primary text-white hover:bg-primary/95 py-3.5 px-6 rounded-xl font-bold transition-all duration-200 shadow-md hover:shadow-lg transform active:scale-[0.99] cursor-pointer"
      >
        <Send class="w-4 h-4 text-accent stroke-[2.5]" />
        Kirim Pesanan Jasa
      </button>
    </div>

  </form>
</div>

<script>
  function autoSelectService() {
    const urlParams = new URLSearchParams(window.location.search);
    const slug = urlParams.get('slug');
    
    if (slug) {
      const selectElement = document.getElementById('client-service') as HTMLSelectElement;
      if (selectElement) {
        const hasOption = Array.from(selectElement.options).some(option => option.value === slug);
        if (hasOption) {
          selectElement.value = slug;
        }
      }
    }
  }

  // Tetap panggil fungsi autoSelect saat DOM dimuat halaman
  document.addEventListener('DOMContentLoaded', autoSelectService);

  const form = document.getElementById('order-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const formData = new FormData(form as HTMLFormElement);
    const name = formData.get('name');
    const phone = formData.get('phone');
    const address = formData.get('address');
    
    const serviceSelect = document.getElementById('client-service') as HTMLSelectElement;
    const serviceName = serviceSelect.options[serviceSelect.selectedIndex].text;
    
    const schedule = formData.get('schedule');
    const notes = formData.get('notes') || '-';

    // PERBAIKAN: Format teks pesan WhatsApp disesuaikan persis dengan template baru Anda
    const waText = `Halo BREGAS ELEKTRIK,\n` +
                   `Saya ingin mengajukan permintaan layanan dengan rincian sebagai berikut:\n` +
                   `━━━━━━━━━━━━━━━━━━\n` +
                   `DATA PELANGGAN\n` +
                   `• Nama : ${name}\n` +
                   `• Nomor HP : ${phone}\n` +
                   `• Alamat : ${address}\n` +
                   `LAYANAN\n` +
                   `• Jenis Layanan : ${serviceName}\n` +
                   `JADWAL PENGERJAAN\n` +
                   `• Tanggal : ${schedule}\n` +
                   `KETERANGAN TAMBAHAN\n` +
                   `• ${notes}\n` +
                   `━━━━━━━━━━━━━━━━━━\n` +
                   `Mohon konfirmasi terkait ketersediaan jadwal, estimasi biaya, serta proses selanjutnya.\n` +
                   `Terima kasih.`;

    const waNumber = "6285712425961"; 
    const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(waText)}`;
    
    window.open(waUrl, '_blank');
  });
</script>