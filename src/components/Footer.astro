---
// src/components/Footer.astro
import { MapPin, MessageCircle, Mail, Facebook, Instagram } from 'lucide-astro';

const currentYear = new Date().getFullYear();

const menuTentang = [
  { name: 'Profil Kami', href: '/#tentang' },
  { name: 'Visi & Misi', href: '/#tentang' },
  { name: 'Komitmen K3', href: '/#tentang' },
];

const menuLayanan = [
  { name: 'Instalasi Listrik Rumah', href: '/#layanan' },
  { name: 'Instalasi Listrik Ruko & Toko', href: '/#layanan' },
  { name: 'Penambahan Daya Listrik', href: '/#layanan' },
  { name: 'Pemasangan & Penggantian MCB', href: '/#layanan' },
  { name: 'Perbaikan Instalasi Listrik', href: '/#layanan' },
  { name: 'Pemasangan Lampu & Stop Kontak', href: '/#layanan' },
  { name: 'Pengecekan & Perawatan Instalasi', href: '/#layanan' }
];

const waNumber = "6285712425961";
const waLink = `https://wa.me/${waNumber}?text=Halo%20Bregas%20Elektrik,%20saya%20ingin%20berkonsultasi%20mengenai%20layanan.`;
---

<footer class="bg-primary text-white border-t border-border-custom/20 pt-16 pb-12 sm:pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
    
    <div class="space-y-4">
      <a href="/" class="flex items-center gap-2 font-black text-lg tracking-wider text-white">
        <span class="text-accent text-xl">⚡</span> BREGAS ELEKTRIK
      </a>
      <p class="text-text-light/80 text-xs sm:text-sm leading-relaxed font-normal text-left">
        Penyedia jasa rekayasa instalasi kelistrikan profesional berstandar nasional PUIL (Persyaratan Umum Instalasi Listrik) & SNI. Kami mengedepankan aspek proteksi dini dan keselamatan kerja K3.
      </p>
      <div class="flex items-center gap-3.5 pt-2">
        <a href="#" class="p-2 bg-white/5 hover:bg-accent hover:text-primary rounded-xl transition-all duration-200 text-text-light" aria-label="Facebook">
          <Facebook class="h-4 w-4" />
        </a>
        <a href="#" class="p-2 bg-white/5 hover:bg-accent hover:text-primary rounded-xl transition-all duration-200 text-text-light" aria-label="Instagram">
          <Instagram class="h-4 w-4" />
        </a>
        <a href="#" class="p-2 bg-white/5 hover:bg-accent hover:text-primary rounded-xl transition-all duration-200 text-text-light flex items-center justify-center" aria-label="TikTok">
          <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.03 1.6 4.17 1.22 1.32 2.94 2.05 4.72 2.18v3.91c-1.34-.17-2.65-.67-3.74-1.48-.96-.71-1.72-1.65-2.23-2.73v7.94c.05 1.56-.37 3.12-1.2 4.43-1.42 2.13-3.95 3.33-6.5 2.98-2.65-.4-4.88-2.31-5.58-4.89-.79-3 .83-6.19 3.73-7.22 1.03-.36 2.13-.41 3.19-.17v4.03c-.62-.19-1.29-.19-1.92-.02-1.24.32-2.16 1.4-2.29 2.67-.17 1.7 1.15 3.19 2.85 3.32 1.44.11 2.8-.75 3.25-2.11.13-.41.18-.84.17-1.28V0z"/>
          </svg>
        </a>
      </div>
    </div>

    <div>
      <h3 class="text-xs font-bold tracking-widest uppercase text-accent mb-4">Tentang Kami</h3>
      <ul class="space-y-3">
        {menuTentang.map(item => (
          <li>
            <a href={item.href} class="text-xs sm:text-sm text-text-light/90 hover:text-accent transition-colors font-medium">
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-xs font-bold tracking-widest uppercase text-accent mb-4">Layanan</h3>
      <ul class="space-y-3">
        {menuLayanan.map(item => (
          <li>
            <a href={item.href} class="text-xs sm:text-sm text-text-light/90 hover:text-accent transition-colors font-medium block truncate">
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="space-y-4">
      <h3 class="text-xs font-bold tracking-widest uppercase text-accent mb-4">Hubungi Kami</h3>
      <ul class="space-y-3.5 text-xs sm:text-sm text-text-light/90">
        <li class="flex items-start gap-3">
          <MapPin class="h-4 w-4 text-accent shrink-0 mt-0.5" />
          <span class="leading-relaxed">Jl. Gumayun No. 12, Tegal, Jawa Tengah</span>
        </li>
        <li class="flex items-center gap-3">
          <MessageCircle class="h-4 w-4 text-accent shrink-0" />
          <a href={waLink} target="_blank" rel="noopener noreferrer" class="hover:text-accent font-bold transition-colors">
            +6285712425961
          </a>
        </li>
        <li class="flex items-center gap-3">
          <Mail class="h-4 w-4 text-accent shrink-0" />
          <a href="mailto:info@bregaselektrik.com" class="hover:text-accent transition-colors">
            info@bregaselektrik.com
          </a>
        </li>
      </ul>

      {/* TANPA GARIS DAN GABUNG: Langsung menyatu di bawah list kontak khusus mobile */}
      <div class="block sm:hidden pt-2 space-y-2 text-xs font-bold uppercase tracking-wider text-text-light/70">
        <a href="/kebijakanPrivasi" class="block hover:text-accent transition-colors py-1">Kebijakan Privasi</a>
        <a href="/syaratKetentuan" class="block hover:text-accent transition-colors py-1">Syarat & Ketentuan</a>
      </div>
    </div>
  </div>

  {/* BARIS COPYRIGHT & MENU DESKTOP */}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-[11px] font-bold uppercase tracking-wider text-text-light/60 w-full sm:w-auto text-center sm:text-left">
      &copy; {currentYear} BREGAS ELEKTRIK. ALL RIGHTS RESERVED.
    </p>
    
    <div class="hidden sm:flex flex-wrap gap-x-6 gap-y-2 text-[11px] font-bold uppercase tracking-wider text-text-light/60 w-full sm:w-auto justify-end">
      <a href="/kebijakanPrivasi" class="hover:text-accent transition-colors py-1">Kebijakan Privasi</a>
      <a href="/syaratKetentuan" class="hover:text-accent transition-colors py-1">Syarat & Ketentuan</a>
    </div>
  </div>
</footer>